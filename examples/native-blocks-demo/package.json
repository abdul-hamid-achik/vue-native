{
  "name": "@thelacanians/vue-native-example-native-blocks-demo",
  "version": "0.0.10",
  "private": true,
  "description": "Source-only Vue Native <native> block code-generation demo",
  "scripts": {
    "build": "vite build",
    "dev": "vue-native dev --platform ios",
    "dev:ios": "vue-native dev --platform ios",
    "dev:android": "vue-native dev --platform android",
    "dev:macos": "vue-native dev --platform macos",
    "create:host": "vue-native create",
    "generate": "vue-native generate --clean --ios-output generated/ios --android-output generated/android --macos-output generated/macos --ts-output app/generated",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "@thelacanians/vue-native-runtime": "workspace:*",
    "@thelacanians/vue-native-navigation": "workspace:*"
  },
  "devDependencies": {
    "@thelacanians/vue-native-cli": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.5",
    "@thelacanians/vue-native-vite-plugin": "workspace:*",
    "vite": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
