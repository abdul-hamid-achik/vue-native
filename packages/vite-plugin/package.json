{
  "name": "@thelacanians/vue-native-vite-plugin",
  "version": "0.6.4",
  "description": "Vite plugin for Vue Native — builds IIFE bundles for native runtimes",
  "license": "MIT",
  "author": "Vue Native Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdul-hamid-achik/vue-native",
    "directory": "packages/vite-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thelacanians/vue-native-sfc-parser": "^0.6.4",
    "@thelacanians/vue-native-codegen": "^0.6.4",
    "fast-glob": "^3.3.2"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0",
    "@vitejs/plugin-vue": "^5.2.0 || ^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
