{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/runtime": {
      "ignoreDependencies": ["@vue/shared"]
    },
    "packages/navigation": {},
    "packages/vite-plugin": {
      "ignoreDependencies": ["vite"]
    },
    "packages/cli": {},
    "examples/*": {},
    "examples/native-blocks-demo": {
      "ignore": ["app/**"],
      "ignoreDependencies": ["@thelacanians/vue-native-runtime", "@thelacanians/vue-native-navigation"],
      "ignoreBinaries": ["vue-native"]
    }
  },
  "ignore": [
    "native/**",
    "docs/**",
    "tools/**",
    "**/*.d.ts"
  ],
  "exclude": ["classMembers", "exports", "types"],
  "ignoreBinaries": ["maestro", "swift"]
}
