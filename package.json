{
  "name": "vue-native-monorepo",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs",
    "tools/*"
  ],
  "vueNative": {
    "vueCohort": {
      "active": "3.5.40",
      "next": "3.6.0-rc.1"
    }
  },
  "overrides": {
    "vue": "3.5.40",
    "@vue/compiler-core": "3.5.40",
    "@vue/compiler-dom": "3.5.40",
    "@vue/compiler-sfc": "3.5.40",
    "@vue/compiler-ssr": "3.5.40",
    "@vue/reactivity": "3.5.40",
    "@vue/runtime-core": "3.5.40",
    "@vue/runtime-dom": "3.5.40",
    "@vue/server-renderer": "3.5.40",
    "@vue/shared": "3.5.40"
  },
  "scripts": {
    "build": "turbo run build",
    "build:ios": "cd native/ios/VueNativeCore && xcodebuild build -scheme VueNativeCore -destination 'platform=iOS Simulator,name=iPhone 17,OS=latest' -quiet",
    "dev": "turbo run dev",
    "test": "turbo run test && bun run test:ios && bun run test:android && bun run test:shared && bun run test:macos",
    "test:ts": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --no-warn-ignored",
    "knip": "knip --treat-config-hints-as-errors",
    "contracts:check": "bun scripts/check-native-contracts.mjs",
    "check:package-metadata": "bun scripts/sync-package-metadata.mjs --check",
    "check:vue-cohort": "node --test scripts/__tests__/*.test.mjs && bun scripts/check-vue-cohort.mjs",
    "package-metadata:sync": "bun scripts/sync-package-metadata.mjs --write",
    "vue:cohort:set": "bun scripts/set-vue-cohort.mjs",
    "smoke:cli": "bun scripts/smoke-cli-scaffold.mjs",
    "hooks:validate": "lefthook validate",
    "check:ts": "bun run lint && bun run typecheck && bun run contracts:check && bun run check:vue-cohort && bun run check:package-metadata && bun run build && bun run smoke:cli && bun run test:ts && bun run knip && bun run hooks:validate",
    "prepare": "lefthook install",
    "version": "changeset version",
    "release": "changeset publish",
    "version:check": "changeset status",
    "test:ios": "cd native/ios/VueNativeCore && xcodebuild test -scheme VueNativeCore -destination 'platform=iOS Simulator,name=iPhone 17,OS=latest' -quiet",
    "test:android": "cd native/android && ./gradlew :VueNativeCore:testDebugUnitTest",
    "test:shared": "cd native/shared/VueNativeShared && swift test",
    "test:macos": "cd native/macos/VueNativeMacOS && swift test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "eslint": "^9.20.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.0.0",
    "knip": "^5.85.0",
    "lefthook": "^2.1.1",
    "semver": "^7.7.4",
    "turbo": "^2.8.12",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0",
    "vue-eslint-parser": "^10.1.0"
  }
}
